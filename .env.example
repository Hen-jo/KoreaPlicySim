# LLM API settings (supports any OpenAI SDK-compatible LLM API)
# Default example below uses the OpenAI API with GPT-5.2.
# Costs can be significant, so start with short simulations first.
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-5.2

# ===== ZEP graph-memory settings =====
# The free monthly tier is enough for light usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Accelerated LLM settings (optional) =====
# If you do not use the accelerated configuration, omit the variables below from the env file.
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
